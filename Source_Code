// I2C functions
void I2C_init(void) {
 TWSR = 0x00;
 TWBR = 72;
 TWCR = (1<<TWEN);
}
void I2C_start(void) {
 TWCR = (1<<TWINT) | (1<<TWSTA) | (1<<TWEN);
 while (!(TWCR & (1<<TWINT)));
}
void I2C_stop(void) {
 TWCR = (1<<TWINT) | (1<<TWSTO) | (1<<TWEN);
 _delay_us(10);
}
void I2C_write(uint8_t data) {
 TWDR = data;
 TWCR = (1<<TWINT) | (1<<TWEN);
 while (!(TWCR & (1<<TWINT)));
}
uint8_t I2C_read(uint8_t ack) {
 TWCR = (1<<TWINT) | (1<<TWEN) | (ack ? (1<<TWEA) : 0);

 while (!(TWCR & (1<<TWINT)));
 return TWDR;
}
// LCD functions
void LCD_sendNibble(uint8_t data) {
 I2C_start();
 I2C_write(LCD_ADDR << 1);
 I2C_write(data | 0x08);
 I2C_write((data & ~0x04) | 0x08);
 I2C_stop();
 _delay_us(50);
}
void LCD_sendByte(uint8_t value, uint8_t mode) {
 uint8_t high = (value & 0xF0) | (mode ? 0x01 : 0) | 0x08;
 uint8_t low = ((value << 4) & 0xF0) | (mode ? 0x01 : 0) | 0x08;
 LCD_sendNibble(high | 0x04);
 LCD_sendNibble(low | 0x04);
}
void LCD_cmd(uint8_t cmd) {
 LCD_sendByte(cmd, 0);
 if (cmd == 0x01 || cmd == 0x02) _delay_ms(2);
}
void LCD_data(uint8_t data) {
 LCD_sendByte(data, 1);
}

void LCD_init(void) {
 _delay_ms(50);
 LCD_cmd(0x33);
 LCD_cmd(0x32);
 LCD_cmd(0x28);
 LCD_cmd(0x0C);
 LCD_cmd(0x06);
 LCD_cmd(0x01);
 _delay_ms(2);
}
void LCD_setCursor(uint8_t col, uint8_t row) {
 uint8_t row_offsets[] = {0x00, 0x40};
 LCD_cmd(0x80 | (col + row_offsets[row]));
}
void LCD_print(const char *str) {
 while (*str) LCD_data(*str++);
}
void LCD_printf(const char *fmt, ...) {
 char buffer[32];
 va_list args;
 va_start(args, fmt);
 vsnprintf(buffer, sizeof(buffer), fmt, args);
 va_end(args);

 char *p = buffer;

 while (*p) {
 LCD_data(*p++);
 }
}
void LCD_clear(void) {
 LCD_cmd(0x01);
 _delay_ms(2);
}
// Keypad functions for PCF8574
void keypad_init(void) {
 // No initialization needed for PCF8574
}
char keypad_getkey(void) {
 static uint8_t key_pressed = 0;
 char key = 0;

 // Scan each row using PCF8574
 for (uint8_t row = 0; row < 4; row++) {
 // Set all rows high (inactive), columns as inputs with pull-ups
 uint8_t output_byte = 0xFF;

 // Set current row low (active)
 output_byte &= ~(1 << row);

 // Write to keypad PCF8574
 I2C_start();

 I2C_write(KEYPAD_PCF8574_ADDR << 1);
 I2C_write(output_byte);
 I2C_stop();

 _delay_us(10); // Small delay for stabilization

 // Read from keypad PCF8574
 I2C_start();
 I2C_write((KEYPAD_PCF8574_ADDR << 1) | 1);
 uint8_t input_byte = I2C_read(0); // Read with NACK
 I2C_stop();

 // Check each column
 for (uint8_t col = 0; col < 4; col++) {
 if (!(input_byte & (1 << (col + 4)))) {
 // Simple debounce
 _delay_ms(20);

 // Read again to confirm
 I2C_start();
 I2C_write((KEYPAD_PCF8574_ADDR << 1) | 1);
 input_byte = I2C_read(0);
 I2C_stop();

 if (!(input_byte & (1 << (col + 4)))) {
 key = keymap[row][col];

 // Wait for key release
 uint8_t released = 0;

 while (!released) {
 I2C_start();
 I2C_write((KEYPAD_PCF8574_ADDR << 1) | 1);
 input_byte = I2C_read(0);
 I2C_stop();

 if (input_byte & (1 << (col + 4))) {
 released = 1;
 }
 }

 // Only return key if it's a new press
 if (!key_pressed) {
 key_pressed = 1;
 return key;
 }
 }
 }
 }
 }

 // No key pressed
 key_pressed = 0;
 return 0;
}
